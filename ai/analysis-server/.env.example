# ChainWatch AI Analysis Server 환경 설정
# 이 파일은 gitignore 대상입니다. 실제 키를 여기에 입력하세요.

# ── 프로바이더 선택 ─────────────────────────────────────
# 요청에 provider가 없을 때 사용할 기본 프로바이더
CHAINWATCH_AI_DEFAULT_PROVIDER=claude
# 실패 시 폴백 순서 (설정된 프로바이더만 등록됨, mock은 항상 사용 가능)
CHAINWATCH_AI_FALLBACK_CHAIN=claude,gemini,lmstudio,hermes,mock

# ── Claude (Anthropic) ─────────────────────────────────
# 키를 입력하면 Claude 어댑터가 활성화됩니다.
CHAINWATCH_AI_ANTHROPIC_API_KEY=
CHAINWATCH_AI_CLAUDE_MODEL=claude-opus-4-8
CHAINWATCH_AI_CLAUDE_MAX_TOKENS=4096

# ── Gemini (Google) ────────────────────────────────────
CHAINWATCH_AI_GEMINI_API_KEY=
CHAINWATCH_AI_GEMINI_MODEL=gemini-flash-latest

# ── LM Studio (로컬 OpenAI 호환 서버) ───────────────────
# LM Studio 앱에서 서버 시작 후 URL 입력 (기본 포트 1234)
CHAINWATCH_AI_LMSTUDIO_BASE_URL=
CHAINWATCH_AI_LMSTUDIO_MODEL=local-model

# ── Hermes (OpenAI 호환 엔드포인트) ─────────────────────
CHAINWATCH_AI_HERMES_BASE_URL=
CHAINWATCH_AI_HERMES_MODEL=hermes

# ── 재시도/폴백 정책 ────────────────────────────────────
CHAINWATCH_AI_RETRY_MAX_ATTEMPTS=2
CHAINWATCH_AI_RETRY_BACKOFF_SECONDS=0.5
