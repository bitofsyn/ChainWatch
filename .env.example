# ChainWatch 환경변수 템플릿
# 복사해서 사용: cp .env.example .env
# .env는 gitignore 대상이며 실제 키/비밀번호는 절대 커밋하지 않습니다.

# ── 외부 API 키 ──────────────────────────────
# Etherscan (트랜잭션 수집) — https://etherscan.io/apis
CHAINWATCH_ETHERSCAN_API_KEY=
# AI 분석 서버 LLM 제공자 키 (사용하는 것만 설정)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── AI 분석 서버 ─────────────────────────────
CHAINWATCH_AI_ENABLED=true
CHAINWATCH_AI_DEFAULT_PROVIDER=claude
CHAINWATCH_AI_FALLBACK_CHAIN=gemini
CHAINWATCH_AI_GEMINI_MODEL=gemini-2.0-flash
CHAINWATCH_AI_WORKER_POLL_INTERVAL_MS=5000
CHAINWATCH_AI_WORKER_BATCH_SIZE=3

# ── 수집기 ──────────────────────────────────
CHAINWATCH_COLLECTOR_ENABLED=true
# ETHEREUM_RPC_HTTP_URL=
# ETHEREUM_RPC_WS_URL=

# ── 인증 (프로덕션에서는 반드시 재설정) ─────────
# CHAINWATCH_JWT_ENABLED=true
# CHAINWATCH_JWT_SECRET=
# CHAINWATCH_ADMIN_PASSWORD=
# CHAINWATCH_ANALYST_PASSWORD=

# ── 알림 (URL 미설정 시 자동 비활성) ────────────
# CHAINWATCH_SLACK_WEBHOOK_URL=
# CHAINWATCH_DISCORD_WEBHOOK_URL=

# ── 모니터링 ─────────────────────────────────
# GRAFANA_ADMIN_USER=
# GRAFANA_ADMIN_PASSWORD=
